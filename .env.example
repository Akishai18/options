# StratLab — environment variables.
# Copy this file to `.env` at the repo root and fill in real values.
# `.env` is gitignored.
#
# Naming convention:
#   - StratLab-internal config uses STRATLAB_ prefix (matches config.py env_prefix).
#   - Third-party SDKs that read their own envs (e.g. ANTHROPIC_API_KEY) keep
#     their conventional names so the SDK can pick them up automatically.

# =====================================================================
# Core (required for all modes)
# =====================================================================

# Bypass auth — every request authenticates as the same dev user. Local only.
STRATLAB_DEV_MODE=true

# HS256 secret used to verify Supabase-issued JWTs in production.
# Find it in Supabase: Settings → API → JWT Secret.
# STRATLAB_SUPABASE_JWT_SECRET=

# Allowed CORS origins (Next.js dev server + your prod domain).
# STRATLAB_CORS_ORIGINS=["http://localhost:3000","https://stratlab.example.com"]

# =====================================================================
# LLM — Gemini (free tier, default)
# =====================================================================

# Get a key from https://aistudio.google.com/app/apikey  (free, no card required).
STRATLAB_GEMINI_API_KEY=

# Override models if you upgrade to paid AI Studio billing (gemini-2.5-pro etc).
# STRATLAB_LLM_MODEL_PARSE=gemini-2.5-flash
# STRATLAB_LLM_MODEL_CRITIQUE=gemini-2.5-flash

# =====================================================================
# Sentry — error tracking (optional but recommended)
# =====================================================================

# DSN format: https://<key>@oXXXX.ingest.us.sentry.io/<project_id>
# STRATLAB_SENTRY_DSN_BACKEND=
# NEXT_PUBLIC_SENTRY_DSN_FRONTEND=

# =====================================================================
# Supabase — auth + persistent storage (M2 external half)
# =====================================================================

# STRATLAB_SUPABASE_URL=https://<project>.supabase.co
# STRATLAB_SUPABASE_ANON_KEY=
# STRATLAB_SUPABASE_SERVICE_ROLE_KEY=

# Public-facing keys consumed by Next.js (must be NEXT_PUBLIC_* to ship to the browser).
# NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# =====================================================================
# Web → API URL override (optional)
# =====================================================================

# Where the Next.js rewrite proxies /api/* to. Defaults to localhost:8000.
# STRATLAB_API_URL=http://localhost:8000

# =====================================================================
# Anthropic — alternative LLM provider (planned)
# =====================================================================

# Reserved for the future Anthropic provider; not used in V1 (we use Gemini).
# ANTHROPIC_API_KEY=
