# StratLab environment variables
# Copy to .env (project root) and fill in. .env is gitignored.
#
# Naming convention:
#   - StratLab-internal config uses STRATLAB_ prefix (matches config.py env_prefix).
#   - Third-party SDKs (Anthropic) keep their own conventional names so the SDK
#     can pick them up automatically without us forwarding.

# --- StratLab core ---
# STRATLAB_DEV_MODE=true               # bypass auth for local dev (default: true)
# STRATLAB_JWT_SECRET=                 # HS256 secret; set to your Supabase JWT secret in prod

# --- Sentry (M2+) — error tracking ---
# STRATLAB_SENTRY_DSN_BACKEND=https://<key>@oXXXXXX.ingest.us.sentry.io/<project_id>
# STRATLAB_SENTRY_DSN_FRONTEND=        # for the Next.js app, M3+

# --- Supabase (M2 external half) ---
# STRATLAB_SUPABASE_URL=
# STRATLAB_SUPABASE_ANON_KEY=
# STRATLAB_SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (M3+) — uses SDK's own env var name ---
ANTHROPIC_API_KEY=
